# Production environment variables.
# Fill these from your PRODUCTION Supabase project. Keep the real .env.prod out
# of version control (only this .example is committed).

# --- Supabase project ---
# API keys: Dashboard > Project Settings > API Keys.
# Publishable key (sb_publishable_...) is safe for browsers/clients.
# Secret key (sb_secret_...) is server-only — never expose it client-side.
# SUPABASE_URL is also the source of the JWKS used to verify access tokens.
SUPABASE_URL=https://your-prod-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-prod-publishable-key
SUPABASE_SECRET_KEY=sb_secret_your-prod-secret-key

# --- JWT verification ---
# Access tokens are signed with the project's asymmetric JWT Signing Key and
# verified against the project's JWKS endpoint, derived from SUPABASE_URL:
#   <SUPABASE_URL>/auth/v1/.well-known/jwks.json
# (Dashboard > Project Settings > JWT Keys.) No shared secret is required.
SUPABASE_JWT_AUDIENCE=authenticated
# Cookie the user-service and the game-service WebSockets read the JWT access
# token from.
AUTH_COOKIE_NAME=access_token
# game-service: Redis durable store for game/session state + Socket.IO adapter.
REDIS_URL=redis://game-redis:6379

# --- Supabase Postgres connection ---
# Use the IPv4 connection pooler (Supavisor), NOT the direct db.<ref>.supabase.co
# host — that host is IPv6-only and unreachable from Docker / most networks.
# Get it from: Project Settings > Database > Connection pooling.
#   - host: aws-<n>-<region>.pooler.supabase.com   (IPv4)
#   - user: postgres.<project-ref>                 (the ref suffix is required)
#   - port: 5432 (session mode) or 6543 (transaction mode)
#   - URL-encode special chars in the password (e.g. @ -> %40)
DATABASE_URL=postgresql://postgres.your-prod-ref:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
